// Combined guest world: a wasi:http handler that also imports wasi:keyvalue.
// Built to a component with `cargo build --release --target wasm32-wasip2`;
// consumed as a fixture by the boatramp-handlers engine tests to exercise the
// keyvalue host binding end-to-end.
package boatramp:caps-example;

world handler {
  include wasi:http/proxy@0.2.0;
  import wasi:keyvalue/store@0.2.0-draft;
  import wasi:keyvalue/atomics@0.2.0-draft;
}
