// Combined guest world: a wasi:http handler that also imports the boatramp
// `sql` capability. Built to a component with
// `cargo build --release --target wasm32-wasip2`; consumed as a fixture by the
// boatramp-server conformance tests to exercise the sql binding end to end
// (a component serving requests with sql).
package boatramp:caps-example;

world handler {
  include wasi:http/proxy@0.2.0;
  import boatramp:handlers/sql-query;
}
